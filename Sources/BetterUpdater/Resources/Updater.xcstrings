    "BetterAudio is running from a temporary location and cannot install updates from here. Move it to your Applications folder to continue." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BetterAudio wird von einem temporären Speicherort ausgeführt und kann von dort keine Updates installieren. Verschiebe es in den Ordner „Programme“, um fortzufahren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BetterAudio is running from a temporary location and cannot install updates from here. Move it to your Applications folder to continue."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BetterAudio se está ejecutando desde una ubicación temporal y no puede instalar actualizaciones desde ahí. Muévelo a la carpeta Aplicaciones para continuar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BetterAudio s’exécute depuis un emplacement temporaire et ne peut pas installer les mises à jour depuis celui-ci. Déplacez-le dans le dossier Applications pour continuer."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BetterAudio è in esecuzione da una posizione temporanea e non può installare aggiornamenti da lì. Spostalo nella cartella Applicazioni per continuare."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BetterAudio wordt uitgevoerd vanaf een tijdelijke locatie en kan vanaf daar geen updates installeren. Verplaats het naar je map Programma’s om door te gaan."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BetterAudio działa z tymczasowej lokalizacji i nie może stamtąd instalować aktualizacji. Przenieś go do folderu Aplikacje, aby kontynuować."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BetterAudio 正从临时位置运行，无法从此处安装更新。请将它移到“应用程序”文件夹以继续。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BetterAudio 正從暫存位置執行，無法從此處安裝更新。請將它移到「應用程式」檔案夾以繼續。"
          }
        }
      }
    },
