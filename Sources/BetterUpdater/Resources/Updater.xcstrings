    "The update has been downloaded. Please drag the new BetterAudio app to your Applications folder to complete the installation.\n\nAfter installation, restart BetterAudio." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das Update wurde heruntergeladen. Bitte ziehe die neue BetterAudio-App in deinen Programme-Ordner, um die Installation abzuschließen.\n\nStarte BetterAudio nach der Installation neu."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The update has been downloaded. Please drag the new BetterAudio app to your Applications folder to complete the installation.\n\nAfter installation, restart BetterAudio."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La actualización se ha descargado. Arrastra la nueva app BetterAudio a tu carpeta de Aplicaciones para completar la instalación.\n\nDespués de la instalación, reinicia BetterAudio."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La mise à jour a été téléchargée. Veuillez glisser la nouvelle application BetterAudio dans votre dossier Applications pour terminer l'installation.\n\nAprès l'installation, redémarrez BetterAudio."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'aggiornamento è stato scaricato. Trascina la nuova app BetterAudio nella cartella Applicazioni per completare l'installazione.\n\nDopo l'installazione, riavvia BetterAudio."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "De update is gedownload. Sleep de nieuwe BetterAudio-app naar je map Programma's om de installatie te voltooien.\n\nStart BetterAudio opnieuw na de installatie."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aktualizacja została pobrana. Przeciągnij nową aplikację BetterAudio do folderu Aplikacje, aby zakończyć instalację.\n\nPo instalacji uruchom ponownie BetterAudio."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "更新已下载。请将新的 BetterAudio 应用拖到应用程序文件夹以完成安装。\n\n安装后，请重新启动 BetterAudio。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "更新已下載。請將新的 BetterAudio 應用拖到應用程式文件夾以完成安裝。\n\n安裝後，請重新啟動 BetterAudio。"
          }
        }
      }
